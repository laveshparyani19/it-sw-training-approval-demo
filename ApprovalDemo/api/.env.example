# Copy to .env and set values locally (never commit .env).
# PowerShell: Get-Content .env | ForEach-Object { if ($_ -match '^([^#][^=]+)=(.*)$') { Set-Item -Path env:$($matches[1]) -Value $matches[2] } }
# Or set the same names in your shell before `dotnet run`.

SUPABASE_CONNECTION_STRING=Host=db.<project-ref>.supabase.co;Port=5432;Username=postgres;Password=<password>;Database=postgres;SSL Mode=Require;Trust Server Certificate=true

# SQL Server mirror (local example — use your server; Render needs a cloud-accessible SQL endpoint)
MSSQL_CONNECTION_STRING=Server=localhost;Database=ApprovalDemoDb;User Id=sa;Password=<password>;Encrypt=False;TrustServerCertificate=True

# Web API on Render: use false (or omit MSSQL_CONNECTION_STRING) so cloud does not hit local SQL.
# Hybrid sync worker on your PC: worker forces sync on; keep MSSQL_* set locally only.
ENABLE_MSSQL_SYNC=true
